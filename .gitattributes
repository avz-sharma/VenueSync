# Normalize all Python and config files to LF in the repository
# so black --check passes consistently on both Linux (CI) and Windows (local).

*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf
*.gitignore text eol=lf

# Binary files — do not touch line endings
*.png       binary
*.jpg       binary
*.ico       binary
*.woff2     binary
*.ttf       binary
